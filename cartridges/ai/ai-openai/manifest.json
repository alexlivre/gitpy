{
    "identity": {
        "name": "ai-openai",
        "version": "1.0.0",
        "description": "Adapter LLM: OpenAI GPT. Implementa a interface LLMProvider.",
        "ai_role": "Adaptador de protocolo. Traduz a intenção do Brain para a API específica da OpenAI, lidando com autenticação e tratamento de erros de rede.",
        "sidecar": "none"
    },
    "io_contract": {
        "input_schema": {
            "type": "object",
            "properties": {
                "prompt": {
                    "type": "string"
                },
                "system_instruction": {
                    "type": "string"
                },
                "model": {
                    "type": "string",
                    "default": "gpt-4o-mini"
                },
                "max_tokens": {
                    "type": "integer",
                    "default": 500
                },
                "temperature": {
                    "type": "number",
                    "default": 0.3
                }
            },
            "required": [
                "prompt"
            ]
        },
        "output_schema": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string"
                },
                "tokens_used": {
                    "type": "integer"
                },
                "model_used": {
                    "type": "string"
                }
            }
        }
    },
    "error_dictionary": {
        "API_ERR": "Falha na comunicação com a API OpenAI.",
        "QUOTA_EXC": "Limite de tokens/requisições excedido.",
        "AUTH_FAIL": "Token de API inválido ou expirado."
    }
}