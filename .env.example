# GitPy Environment Variables
# Rename this file to '.env' to use it.
# The `sec-sanitizer` blocks the commit of this file automatically.

# Global AI Settings
# AI_PROVIDER: Defines the default provider (auto, groq, openai, gemini, ollama)
AI_PROVIDER=auto

# Language Settings (Independent)
# LANGUAGE: Interface language (menus, buttons, messages) - Supported: en, pt
# COMMIT_LANGUAGE: Commit message language generated by AI - Supported: en, pt
# Example: LANGUAGE=pt + COMMIT_LANGUAGE=en = Portuguese interface, English commits
LANGUAGE=en
COMMIT_LANGUAGE=en

# Specific Models per Provider
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENROUTER_MODEL=meta-llama/llama-4-scout
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-pro

# -------------------------------------------------------------
# 🟢 SUPPORTED PROVIDERS
# -------------------------------------------------------------

# Groq (Llama 4, Mixtral)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (Gemma-3, Llama-4-Scout)
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# OpenAI (GPT-4o, GPT-5-mini, GPT-5-nano)
# ATTENTION: gpt-5 models use the new `responses` API internally.
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google Gemini (Gemini Pro)
# https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# GitHub Token (For fork/clone via HTTPS)
# https://github.com/settings/tokens
GITHUB_TOKEN=
