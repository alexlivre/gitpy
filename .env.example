# GitPy Environment Variables
# Renomeie este arquivo para '.env' para usá-lo.
# O `sec-sanitizer` bloqueia o commit deste arquivo automaticamente.

# -------------------------------------------------------------
# 🟢 PROVEDORES SUPORTADOS (Atualmente apenas Groq está 100% testado)
# -------------------------------------------------------------

# Groq (Llama 4, Mixtral) - RECOMENDADO / ÚNICO EM FUNCIONAMENTO PLENO
# Obtenha sua chave gratuita em: https://console.groq.com/keys
GROQ_API_KEY=

# -------------------------------------------------------------
# 🚧 FUTUROS PROVEDORES (Ainda em desenvolvimento/testes)
# -------------------------------------------------------------

# OpenAI (GPT-4o) - Em breve
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google Gemini (Gemini Pro) - Em breve
# https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# GitHub Token (Para fork/clone via HTTPS)
# https://github.com/settings/tokens
GITHUB_TOKEN=
