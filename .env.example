# GitPy Environment Variables
# Renomeie este arquivo para '.env' para usá-lo.
# O `sec-sanitizer` bloqueia o commit deste arquivo automaticamente.

# OpenAI (GPT-4o)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini (Gemini Pro)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (Llama 4, Mixtral)
# https://console.groq.com/keys
GROQ_API_KEY=

# GitHub Token (Para fork/clone via HTTPS)
# https://github.com/settings/tokens
GITHUB_TOKEN=
