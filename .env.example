# GitPy Environment Variables
# Renomeie este arquivo para '.env' para usá-lo.
# O `sec-sanitizer` bloqueia o commit deste arquivo automaticamente.

# Configurações Globais de IA
# AI_PROVIDER: Define o provedor padrão (auto, groq, openai, gemini, ollama)
AI_PROVIDER=auto

# AI_MODEL: Define o modelo para TODOS os provedores (Se omitido, usa o padrão do provedor ou as chaves abaixo)
# AI_MODEL=

# Modelos Específicos por Provedor
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-pro

# -------------------------------------------------------------
# 🟢 PROVEDORES SUPORTADOS
# -------------------------------------------------------------

# Groq (Llama 4, Mixtral)
# Obtenha sua chave gratuita em: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (GPT-4o)
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google Gemini (Gemini Pro)
# https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# GitHub Token (Para fork/clone via HTTPS)
# https://github.com/settings/tokens
GITHUB_TOKEN=
